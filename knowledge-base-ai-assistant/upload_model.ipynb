   "source": [
    "Upload model to S3"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import boto3\n",
    "\n",
    "BUCKET_NAME = \"your-bucket-name\"\n",
    "MODEL_PATH = \"path/to/your/model.bin\"\n",
    "S3_KEY = \"models/your-model.bin\"\n",
    "\n",
    "s3 = boto3.client(\"s3\")\n",
    "s3.upload_file(MODEL_PATH, BUCKET_NAME, S3_KEY)\n",
    "\n",
    "print(f\"Uploaded {MODEL_PATH} to s3://{BUCKET_NAME}/{S3_KEY}\")"
   ]
  }
